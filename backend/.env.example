# Локальная разработка
DATABASE_URL="postgresql://username:password@localhost:5432/entechsite"
JWT_SECRET="your-super-secret-jwt-key-here"
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Папка для аватарок и upload-фото (локально — по умолчанию backend/uploads)
# UPLOADS_DIR="./uploads"

# Railway (production):
# 1. Backend → Volumes → Add Volume → mount path: /data/uploads
# 2. Переменная UPLOADS_DIR не нужна — Railway сам задаёт RAILWAY_VOLUME_MOUNT_PATH
# 3. Файлы сохраняются в /data/uploads/avatars и не пропадают при redeploy
