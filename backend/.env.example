# Локальная разработка
DATABASE_URL="postgresql://username:password@localhost:5432/entechsite"
JWT_SECRET="your-super-secret-jwt-key-here"
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# Папка для аватарок и upload-фото (локально — по умолчанию backend/uploads)
# UPLOADS_DIR="./uploads"

# Google Drive (синхронизация «Наша жизнь» и галерея фото)
# 1) Откройте папку «Фотогалерея» на общем диске и скопируйте ID из URL:
#    https://drive.google.com/drive/folders/<GOOGLE_DRIVE_ROOT_FOLDER_PHOTO_ID>
# GOOGLE_DRIVE_ROOT_FOLDER_PHOTO_ID="your_folder_id"
#
# Google Drive (синхронизация «База знаний» / курсы)
# 1) Откройте папку «Обучение» и скопируйте ID из URL:
#    https://drive.google.com/drive/folders/<GOOGLE_DRIVE_ROOT_FOLDER_ID>
# GOOGLE_DRIVE_ROOT_FOLDER_ID="1vKH5IGGEOy-8fF-BRlsWuVRMcJUgZLIJ"
#
# 2) Credentials — один из вариантов:
#    - положите *.json service account в корень репозитория (файл в .gitignore)
#    - GOOGLE_APPLICATION_CREDENTIALS="../jovial-world-....json"
#    - GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'  (для Railway)
#
# 3) На общем диске «Корпоративное» добавьте client_email из JSON как «Читатель»

# Railway (production):
# 1. Backend → Volumes → Add Volume → mount path: /data/uploads
# 2. Переменная UPLOADS_DIR не нужна — Railway сам задаёт RAILWAY_VOLUME_MOUNT_PATH
# 3. Файлы сохраняются в /data/uploads/avatars и не пропадают при redeploy
